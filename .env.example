# ─── AudioBook Creator — Variables de Entorno ────────────────────────────────
#
# 1. Copia este archivo y renómbralo a .env.local para desarrollo local.
# 2. En producción (Vercel), agrégalas en:
#    Dashboard → Tu proyecto → Settings → Environment Variables
#
# IMPORTANTE: NUNCA subas .env.local a git. Ya está en .gitignore.

# Tu API Key de Google AI Studio (aistudio.google.com/apikey)
# Esta key SOLO vive en el servidor — el usuario nunca la ve.
GEMINI_API_KEY=AIzaSy_REEMPLAZA_CON_TU_KEY_REAL

# (Opcional) Restringe qué dominio puede llamar a /api/tts
# En desarrollo puedes dejarlo en * o http://localhost:5173
# En producción pon tu dominio: https://tuapp.vercel.app
ALLOWED_ORIGIN=*
